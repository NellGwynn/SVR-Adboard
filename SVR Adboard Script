// ==================================================
// FUNCTION: CHECK MEMORY USAGE
// ==================================================
check_memory()
{
    integer used = llGetUsedMemory();
    integer free = llGetFreeMemory();
    integer percent = (integer)((used / 65536.0) * 100);
    
    if (debug)
    {
        llOwnerSay("Memory: " + (string)used + "/65536 (" + (string)percent + "%), Free: " + (string)free);
        
        if (used > 60000) // Warning at 90%+
            llOwnerSay("WARNING: Memory usage high!");
    }
}

