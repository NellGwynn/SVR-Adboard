// ==================================================
// FUNCTION: GIVE ITEMS
// ==================================================
give_items(key recipient)
{
    string thisScript = llGetScriptName();
    list inventoryItems;
    integer inventoryNumber = llGetInventoryNumber(INVENTORY_ALL);
    
    // Count system items first
    integer syst_item_count = 0;
    integer i;
    for (i = 0; i < inventoryNumber; i++)
    {
        string itemName = llGetInventoryName(INVENTORY_ALL, i);
        string itemNameUpper = llToUpper(itemName);
        string firstFour = llGetSubString(itemNameUpper, 0, 3);
        if (firstFour == "SYST")
        {
            syst_item_count++;
        }
    }
    
    // Calculate how many renter items we can give
    integer allowed_renter_items = g_items_limit - syst_item_count;
    if (allowed_renter_items < 0) allowed_renter_items = 0;
    
    integer renter_items_given = 0;
    integer syst_items_given = 0;
    
    // First, add all SYST items (they always get priority)
    for (i = 0; i < inventoryNumber && syst_items_given < syst_item_count; i++)
    {
        string itemName = llGetInventoryName(INVENTORY_ALL, i);
        string itemNameUpper = llToUpper(itemName);
        string firstFour = llGetSubString(itemNameUpper, 0, 3);
        
        if (firstFour == "SYST")
        {
            if (llGetInventoryPermMask(itemName, MASK_OWNER) & PERM_COPY)
            {
                inventoryItems += itemName;
                syst_items_given++;
            }
            else if(debug)
            {
                llOwnerSay("DEBUG: Cannot copy SYST item: " + itemName);
            }
        }
    }
    
    // Then add renter items up to the limit
    for (i = 0; i < inventoryNumber && renter_items_given < allowed_renter_items; i++)
    {
        string itemName = llGetInventoryName(INVENTORY_ALL, i);
        string itemNameUpper = llToUpper(itemName);
        string firstFour = llGetSubString(itemNameUpper, 0, 3);
        
        // Only process non-system, non-protected items
        if (firstFour != "CONF" && firstFour != "RENT" && firstFour != "SYST" && itemName != thisScript)
        {
            if (llGetInventoryPermMask(itemName, MASK_OWNER) & PERM_COPY)
            {
                inventoryItems += itemName;
                renter_items_given++;
            }
            else if(debug)
            {
                llOwnerSay("DEBUG: Cannot copy renter item: " + itemName);
            }
        }
    }
    
    // Warn about skipped items
    integer total_items_given = syst_items_given + renter_items_given;
    if (inventoryNumber > total_items_given)
    {
        integer items_skipped = inventoryNumber - total_items_given;
        // Adjust for protected items that shouldn't count
        integer protected_items = 0;
        if (g_rent_nc != "" && llGetInventoryType(g_rent_nc) != INVENTORY_NONE) protected_items++;
        if (g_config_nc != "" && llGetInventoryType(g_config_nc) != INVENTORY_NONE) protected_items++;
        
        integer actual_skipped = items_skipped - protected_items;
        if (actual_skipped > 0)
        {
            llSay(0, "/me -Note: " + (string)total_items_given + " items given (" + 
                 (string)syst_items_given + " system + " + (string)renter_items_given + 
                 " renter). Limit: " + (string)g_items_limit + ". " + 
                 (string)actual_skipped + " item(s) not given.");
        }
    }

    string folderName = g_identifier_ten + "'s " + g_folder_name;

    if (inventoryItems != []) 
    {
        llGiveInventoryList(recipient, folderName, inventoryItems);
        
        string message;
        if (grpgive) 
            message = "Info on: " + g_uri_ten + "\nGroup: " + g_grp_uri;
        else 
            message = "Info on: " + g_uri_ten;
        llInstantMessage(recipient, message);
    }
}

// ==================================================
// FUNCTION: AVATAR ID - CHECK COPY TRANSFER PERMISSIONS
// ==================================================
integer checkCpTransPerms(string itemName)
{
    if (itemName == "") return FALSE;
    integer per = llGetInventoryPermMask(itemName, MASK_NEXT);
    return (per & PERM_TRANSFER) && (per & PERM_COPY);
}

// ==================================================
// FUNCTION: FORMAT TIME
// ==================================================
string fmtRemainTime(integer seconds_remaining)
{
    integer days = llFloor(seconds_remaining / 86400);
    integer hours = llFloor((seconds_remaining % 86400) / 3600);
    integer minutes = llFloor((seconds_remaining % 3600) / 60);
    
    string time_string = "";
    integer item_count = 0;
    
    if (days > 0)
    {
        time_string = (string)days + " day";
        if (days != 1) time_string += "s";
        item_count++;
    }
    
    if (hours > 0)
    {
        if (item_count > 0) time_string += ", ";
        time_string += (string)hours + " hr";
        if (hours != 1) time_string += "s";
        item_count++;
    }
    
    if (minutes > 0)
    {
        if (item_count > 0)
        {
            if (item_count >= 2) time_string += ", and ";
            else time_string += " and ";
        }
        time_string += (string)minutes + " min";
        if (minutes != 1) time_string += "s";
    }
    
    if (time_string == "") time_string = "less than a minute";
    
    return time_string;
}

