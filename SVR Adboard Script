// ==================================================
// MODIFIED PROCESS INVENTORY LOAD WITH TYPE RESTRICTIONS
// ==================================================
processInventoryLoad() 
{
    if(debug) llOwnerSay("Loading inventory");
    g_check = g_check_PROCESSED;
    
    integer count;
    integer startIndex;
    string itemName;
    
    // Process texture (always allowed)
    if (g_texture == "")
    {
        count = llGetInventoryNumber(INVENTORY_TEXTURE);
        if (count > 0)
        {
            itemName = llGetInventoryName(INVENTORY_TEXTURE, 0);
            if (checkCpTransPerms(itemName))
            {
                g_texture = itemName;
                set_texture(g_texture);
                llSay(0, "/me -Texture: " + g_texture);
            }
        }
    }
    
// Process notecard (always allowed, but skip CONF, RENT, and SYST notecards)
if (inv_notecard == "")
{
    count = llGetInventoryNumber(INVENTORY_NOTECARD);
    
    // Look for the first non-system notecard
    integer j;
    for (j = 0; j < count; j++)
    {
        string itemName = llGetInventoryName(INVENTORY_NOTECARD, j);
        string itemUpper = llToUpper(itemName);
        string firstFour = llGetSubString(itemUpper, 0, 3);
        
        // If this is NOT a system notecard, process it
        if (firstFour != "CONF" && firstFour != "RENT" && firstFour != "SYST")
        {
            if (checkCpTransPerms(itemName))
            {
                inv_notecard = itemName;
                llSay(0, "/me -Notecard: " + inv_notecard);
                j = count;  // Exit loop by setting j to count
            }
        }
    }
}
    
    // Process landmark (if allowed)
    if (gb_allow_landmarks && inv_landmark == "")
    {
        count = llGetInventoryNumber(INVENTORY_LANDMARK);
        if (count > 0)
        {
            itemName = llGetInventoryName(INVENTORY_LANDMARK, 0);
            if (checkCpTransPerms(itemName))
            {
                inv_landmark = itemName;
                llSay(0, "/me -Landmark: " + inv_landmark);
            }
        }
    }
    else if (!gb_allow_landmarks)
    {
        // Remove any landmarks if not allowed (but protect SYST landmarks)
        count = llGetInventoryNumber(INVENTORY_LANDMARK);
        integer index = count;
        while (index > 0)
        {
            index--;
            itemName = llGetInventoryName(INVENTORY_LANDMARK, index);
            string itemUpper = llToUpper(itemName);
            string firstFour = llGetSubString(itemUpper, 0, 3);
            
            // MODIFIED: Don't remove SYST landmarks
            if (firstFour != "SYST")
            {
                llSay(0, "/me -Landmarks not allowed: " + itemName + " removed.");
                llRemoveInventory(itemName);
            }
            else if(debug)
            {
                llOwnerSay("DEBUG: Protected SYST landmark: " + itemName);
            }
        }
    }
    
    // Process object (if allowed)
    if (gb_allow_objects && inv_object == "")
    {
        count = llGetInventoryNumber(INVENTORY_OBJECT);
        if (count > 0)
        {
            itemName = llGetInventoryName(INVENTORY_OBJECT, 0);
            if (checkCpTransPerms(itemName))
            {
                inv_object = itemName;
                llSay(0, "/me -Object: " + inv_object);
            }
        }
    }
    else if (!gb_allow_objects)
    {
        // Remove any objects if not allowed (but protect SYST objects)
        count = llGetInventoryNumber(INVENTORY_OBJECT);
        integer index = count;
        while (index > 0)
        {
            index--;
            itemName = llGetInventoryName(INVENTORY_OBJECT, index);
            string itemUpper = llToUpper(itemName);
            string firstFour = llGetSubString(itemUpper, 0, 3);
            
            // MODIFIED: Don't remove SYST objects
            if (firstFour != "SYST")
            {
                llSay(0, "/me -Objects not allowed: " + itemName + " removed.");
                llRemoveInventory(itemName);
            }
            else if(debug)
            {
                llOwnerSay("DEBUG: Protected SYST object: " + itemName);
            }
        }
    }
    
    if(debug) llOwnerSay("Inventory done");
}

notifyRenterReady()
{
    if(debug) llOwnerSay("Notifying renter");
    
    g_check = g_check_NOTIFIED;
    
    if (g_key_ten != NULL_KEY)
    {
        integer current_time = llGetUnixTime();
        integer should_send = FALSE;
        string message_prefix = "";
        
        if (g_notify_count < 2)
        {
            should_send = TRUE;
            if(debug) llOwnerSay("Notice #" + (string)(g_notify_count + 1));
        }
        else if (g_notify_count >= 2)
        {
            if (current_time >= g_next_daily_reminder)
            {
                should_send = TRUE;
                message_prefix = "Reminder: ";
                if(debug) llOwnerSay("Daily reminder");
            }
        }
        
        if (should_send)
        {
            // Shorter message
            string message = message_prefix + "Load content, or if done, touch board and select 'Ready' to start.\n\n";
            
            // Add restrictions info
            if (!gb_allow_landmarks || !gb_allow_objects)
            {
                message += "Note: ";
                if (!gb_allow_landmarks && !gb_allow_objects)
                    message += "Landmarks and objects not allowed. ";
                else if (!gb_allow_landmarks)
                    message += "Landmarks not allowed. ";
                else if (!gb_allow_objects)
                    message += "Objects not allowed. ";
                message += "\n";
            }
            
            if (g_activ_time > 0)
            {
                integer remaining_days = llFloor(g_activ_time / 86400);
                message += "Paid time: " + (string)remaining_days + " days";
            }
            
            llInstantMessage(g_key_ten, message);
            
            g_notify_count++;
            g_last_notify_time = current_time;
            
            if (g_notify_count >= 2)
            {
                g_next_daily_reminder = current_time + 86400;
                if(debug) llOwnerSay("Next daily: " + (string)g_next_daily_reminder);
            }
            
            if (g_notify_count <= 2)
            {
                string announce_msg = "/me -" + llKey2Name(g_key_ten) + "'s content ready.";
                // Add restrictions info to public announcement
                if (!gb_allow_landmarks || !gb_allow_objects)
                {
                    announce_msg += " (";
                    if (!gb_allow_landmarks && !gb_allow_objects)
                        announce_msg += "no landmarks/objects";
                    else if (!gb_allow_landmarks)
                        announce_msg += "no landmarks";
                    else if (!gb_allow_objects)
                        announce_msg += "no objects";
                    announce_msg += ")";
                }
                llSay(0, announce_msg);
            }
        }
    }
}

