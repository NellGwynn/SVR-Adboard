  money(key id, integer amount)
{
    if (id == NULL_KEY) return;
    if(paid + amount > (g_price * g_weeks) || amount < g_price || (gb_active && id != g_key_ten))
    {
        llGiveMoney(id, amount);
        if(gb_active && id != g_key_ten)
            llInstantMessage(id, "Already rented");
        else if (paid + amount > (g_price * g_weeks))
            llInstantMessage(id, "Max weeks");
        else if (amount < g_price)
            llInstantMessage(id, "Too little");
    }
    else
    {
        if(!gb_active) g_begin_time = llGetUnixTime();
        paid += amount;
        integer count = amount / g_price;
        g_activ_time += 604800 * count;
        
        if(!gb_active)
        {
            g_key_ten = id;
            g_waiting_for_renter_data = TRUE;
            g_notify_count = 0;
            g_last_notify_time = 0;
            g_next_daily_reminder = 0;
            online_hide_ten = FALSE;
            g_last_status_change = 0;
            g_initial_notices_sent = 0;
            fun_req_all_data(g_key_ten);
            
            // Count system items for the limit warning
            integer syst_item_count = 0;
            integer inventoryNumber = llGetInventoryNumber(INVENTORY_ALL);
            integer i;
            for (i = 0; i < inventoryNumber; i++)
            {
                string itemName = llGetInventoryName(INVENTORY_ALL, i);
                string itemNameUpper = llToUpper(itemName);
                string firstFour = llGetSubString(itemNameUpper, 0, 3);
                if (firstFour == "SYST")
                {
                    syst_item_count++;
                }
            }
            
            integer allowed_renter_items = g_items_limit - syst_item_count;
            if (allowed_renter_items < 0) allowed_renter_items = 0;
            
            // Add restrictions info to rental message
            string rent_msg = "/me -Payment received! ";
            if (!gb_allow_landmarks || !gb_allow_objects)
            {
                rent_msg += "Note: ";
                if (!gb_allow_landmarks && !gb_allow_objects)
                    rent_msg += "No landmarks or objects. ";
                else if (!gb_allow_landmarks)
                    rent_msg += "No landmarks. ";
                else if (!gb_allow_objects)
                    rent_msg += "No objects. ";
            }
            
            // Item limit warning
            rent_msg += "You can add up to " + (string)allowed_renter_items + 
                       " items (limit: " + (string)g_items_limit + " total - " + 
                       (string)syst_item_count + " system items).";
            
            llSay(0, rent_msg);
            
            gb_active = TRUE;
            llAllowInventoryDrop(TRUE);
            
            // Add restrictions info to drop message
            string drop_msg = "/me -Drop content now";
            if (!gb_allow_landmarks || !gb_allow_objects)
            {
                drop_msg += " (";
                if (!gb_allow_landmarks && !gb_allow_objects)
                    drop_msg += "no LM/OBJ";
                else if (!gb_allow_landmarks)
                    drop_msg += "no LM";
                else if (!gb_allow_objects)
                    drop_msg += "no OBJ";
                drop_msg += ")";
            }
            llSay(0, drop_msg);
            
            g_check = g_check_LOADING;
        }
        llSetTimerEvent(1);
    }
}
    
    dataserver(key query_id, string data)
    {
        if (query_id == g_config_query_id)
        {
            if (data == EOF)
                configurationComplete();
            else
            {
                parseConfigLine(data);
                g_confg_curr_ln++;
                g_config_query_id = llGetNotecardLine(g_config_nc, g_confg_curr_ln);
            }
            return;
        }
        
        if (query_id == g_name_req)
        {
            g_legcy_name = data;
            g_req_pending--;
        }
        else if (query_id == g_online_req)
        {
            if (data == "1") g_online_stat = "Online";
            else if (data == "0") g_online_stat = "Offline";
            else g_online_stat = "Unknown";
            g_req_pending--;
        }
        else if (query_id == g_payinfo_req)
        {
            if (data == "0") g_payinfo_stat = "None";
            else if (data == "1") g_payinfo_stat = "On File";
            else if (data == "2") g_payinfo_stat = "Recent";
            else g_payinfo_stat = "Unknown";
            g_req_pending--;
        }
        else if (query_id == g_disp_name_req)
        {
            g_disp_name = data;
            g_req_pending--;
        }
        else if (query_id == g_user_name_req)
        {
            g_user_name = data;
            g_req_pending--;
        }
        
        if (g_req_pending == 0)
            fun_proc_comp_data();
    }
    
