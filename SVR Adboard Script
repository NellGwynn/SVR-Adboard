// ==================================================
// FUNCTION: CHECK INVENTORY COUNT AND WARN IF TOO MANY
// ==================================================
check_inventory_limit()
{
    integer inventoryNumber = llGetInventoryNumber(INVENTORY_ALL);
    string thisScript = llGetScriptName();
    integer syst_item_count = 0;
    integer total_non_syst_items = 0;
    
    // Count system items and renter items
    integer i;
    for (i = 0; i < inventoryNumber; i++)
    {
        string itemName = llGetInventoryName(INVENTORY_ALL, i);
        string itemNameUpper = llToUpper(itemName);
        string firstFour = llGetSubString(itemNameUpper, 0, 3);
        
        if (firstFour == "SYST")
        {
            syst_item_count++;
        }
        else if (itemName != thisScript && 
                 itemName != g_rent_nc && 
                 itemName != g_config_nc &&
                 firstFour != "CONF" && 
                 firstFour != "RENT")
        {
            total_non_syst_items++;
        }
    }
    
    // Calculate how many renter items are allowed
    integer allowed_renter_items = g_items_limit - syst_item_count;
    if (allowed_renter_items < 0) allowed_renter_items = 0;
    
    // Warn if too many renter items
    if (total_non_syst_items > allowed_renter_items)
    {
        integer excess = total_non_syst_items - allowed_renter_items;
        llSay(0, "/me -WARNING: Too many items! Limit is " + (string)allowed_renter_items + 
              " renter items (excluding " + (string)syst_item_count + " system items). " + 
              (string)excess + " item(s) will not be given out.");
        
        if (gb_active && g_key_ten != NULL_KEY)
        {
            llInstantMessage(g_key_ten, 
                "WARNING: You have " + (string)total_non_syst_items + " items in the board.\n" +
                "Only " + (string)allowed_renter_items + " can be given out (limit: " + 
                (string)g_items_limit + " total - " + (string)syst_item_count + " system items).\n" +
                "Remove " + (string)excess + " item(s) or some won't be delivered.");
        }
    }
}


// ==================================================
// FUNCTION: IDENTITY, CHANNELS, AND LOCATION FUNCTION
// ==================================================
initialize_all()
{
    gid_scrip_nam = llGetScriptName();    
    gid_obj_desc = llGetObjectDesc(); 
    gid_obj_name = llGetObjectName();
    g_obj_key = llGetKey();
    gid_owner = llGetOwner();
    
    if(debug) 
    {
        llOwnerSay("=== IDENTITY ===");
        llOwnerSay("Script: " + gid_scrip_nam);
        llOwnerSay("Object: " + gid_obj_name);
        llOwnerSay("Desc: " + gid_obj_desc);
        llOwnerSay("Key: " + (string)g_obj_key);
        llOwnerSay("===================");
    }
    
    // SET CHANNELS
    string name_prefix;
    if (gb_netwrkd)
    {
        name_prefix = llGetSubString(gid_obj_name, 0, 7);
        while (llStringLength(name_prefix) < 8) name_prefix += "_";
        chan_comm = llHash(name_prefix + g_shared_salt);
        if (chan_comm > 0) chan_comm = -chan_comm;
        if(debug) llOwnerSay("NETWORKED - Chan: " + (string)chan_comm);
    }    
    else
    {
        chan_comm = -999999 - (integer)llFrand(2146483649);
        if(debug) llOwnerSay("STANDALONE - Chan: " + (string)chan_comm);
    }
    
    chan_dialog = chan_comm - 1;
    chan_text_box = chan_comm - 2;
    if (chan_dialog >= 0) chan_dialog = -999999;
    if (chan_text_box >= 0) chan_text_box = -999998;
    
    if(debug) 
    {
        llOwnerSay("Dialog: " + (string)chan_dialog);
        llOwnerSay("Text box: " + (string)chan_text_box);
    }
    
    // SET LOCATION
    string region_name = llGetRegionName();
    vector object_pos = llGetPos();
    gloc_obj_SLURL = "http://maps.secondlife.com/secondlife/"
        + llEscapeURL(region_name) + "/"
        + (string)llRound(object_pos.x) + "/"
        + (string)llRound(object_pos.y) + "/"
        + (string)llRound(object_pos.z) + "/";
    
    if(debug) llOwnerSay("SLURL: " + gloc_obj_SLURL);
    
    // SET GROUP URI
    g_grp_uri = "secondlife:///app/group/" + grpuuid + "/about";
    if(debug) llOwnerSay("Group: " + g_grp_uri);
    
    if(debug) llOwnerSay("Init complete.");
}

//SYST prefix detection
set_notecards() 
{
    g_config_nc = "";
    g_rent_nc = "";
    g_syst_nc = "";  
    
    integer config_count = 0;
    integer rent_count = 0;
    integer syst_count = 0; 
    integer error_count = 0;
    
    integer numNotecards = llGetInventoryNumber(INVENTORY_NOTECARD);
    
    if (numNotecards == 0) 
    {
        llOwnerSay("ERROR: No notecards!");
    }
    
    llOwnerSay("Scanning " + (string)numNotecards + " notecard(s)...");
    
    integer i;
    for (i = 0; i < numNotecards; i++) 
    {
        string notecard_name = llGetInventoryName(INVENTORY_NOTECARD, i);
        string prefix = "";
        
        if (llStringLength(notecard_name) >= 4) 
        {
            prefix = llToUpper(llGetSubString(notecard_name, 0, 3));
        }
        
        if (prefix == prefix_conf) 
        {
            config_count++;
            if (g_config_nc == "") g_config_nc = notecard_name;
            if (config_count > 2) error_count++;
        }
        else if (prefix == prefix_rent) 
        {
            rent_count++;
            if (g_rent_nc == "") g_rent_nc = notecard_name;
            if (rent_count > 2) error_count++;
        }
        else if (prefix == prefix_syst) 
        {
            syst_count++;
            if (g_syst_nc == "") g_syst_nc = notecard_name;
            if (syst_count > 2) error_count++;
        }
    }
    
    string result = "Notecard Scan:";
    result += "\nCONF: " + (string)config_count;
    result += "\nRENT: " + (string)rent_count;
    result += "\nSYST: " + (string)syst_count;  
    
    if (g_config_nc != "") result += "\nUsing CONF: " + g_config_nc;
    else result += "\nNo CONF card!";
        
    if (g_rent_nc != "") result += "\nUsing RENT: " + g_rent_nc;
    else result += "\nNo RENT card!";
    
    if (g_syst_nc != "") result += "\nUsing SYST: " + g_syst_nc;  // ADDED
    // Note: Not having SYST card is not an error
    
    if (error_count > 0) result += "\nERRORS: " + (string)error_count;
    else result += "\nOK";
    
    llOwnerSay(result);
}


