// ==================================================
// FUNCTION: PARSE CONFIGURATION LINE
// ==================================================
parseConfigLine(string line)
{
    line = llStringTrim(line, STRING_TRIM);
    if (line == "" || llGetSubString(line, 0, 0) == "#") return;
    
    integer eq_pos = llSubStringIndex(line, "=");
    if (eq_pos == -1)
    {
        if(debug) llOwnerSay("Bad config: " + line);
        return;
    }
    
    string cfg_key = llStringTrim(llGetSubString(line, 0, eq_pos - 1), STRING_TRIM);
    string cfg_val = llStringTrim(llGetSubString(line, eq_pos + 1, -1), STRING_TRIM);
    
    if (cfg_key == "g_price") g_price = (integer)cfg_val;
    else if (cfg_key == "g_weeks") g_weeks = (integer)cfg_val;
    else if (cfg_key == "g_notify_days") g_notify_days = (integer)cfg_val;
    else if (cfg_key == "g_rent_text") g_rent_text = (key)cfg_val;
    else if (cfg_key == "g_touch_msg") g_touch_msg = cfg_val;
    else if (cfg_key == "g_expir_msg") g_expir_msg = cfg_val;
    else if (cfg_key == "g_folder_name") g_folder_name = cfg_val;
    else if (cfg_key == "prefix_conf") prefix_conf = cfg_val;
    else if (cfg_key == "prefix_rent") prefix_rent = cfg_val;
    else if (cfg_key == "prefix_syst") prefix_syst = cfg_val;  // ADDED: SYST prefix
    else if (cfg_key == "g_shared_salt") g_shared_salt = cfg_val;
    else if (cfg_key == "grpgive") grpgive = (llToLower(cfg_val) == "true");
    else if (cfg_key == "grpuuid") 
    {
        grpuuid = cfg_val;
        g_grp_uri = "secondlife:///app/group/" + grpuuid + "/about";
    }
    else if (cfg_key == "email_desc_ten") email_desc_ten = cfg_val;
    else if (cfg_key == "email_head_ten") email_head_ten = cfg_val;
    else if (cfg_key == "email_body_ten") email_body_ten = cfg_val;
    else if (cfg_key == "gb_own_im") gb_own_im = (llToLower(cfg_val) == "true");
    else if (cfg_key == "gb_own_email") gb_own_email = (llToLower(cfg_val) == "true");
    else if (cfg_key == "gb_own_online") gb_own_online = (llToLower(cfg_val) == "true");
    else if (cfg_key == "email_addr_own") email_addr_own = cfg_val;
    else if (cfg_key == "email_desc_own") email_desc_own = cfg_val;
    else if (cfg_key == "email_head_own") email_head_own = cfg_val;
    else if (cfg_key == "email_body_own") email_body_own = cfg_val;
    else if (cfg_key == "gb_float_text") gb_float_text = (llToLower(cfg_val) == "true");
    else if (cfg_key == "gb_netwrkd") gb_netwrkd = (llToLower(cfg_val) == "true");
    else if (cfg_key == "g_items_limit") g_items_limit = (integer)cfg_val;
    else if (cfg_key == "gb_allow_objects") gb_allow_objects = (llToLower(cfg_val) == "true");
    else if (cfg_key == "gb_allow_landmarks") gb_allow_landmarks = (llToLower(cfg_val) == "true");
    else if (cfg_key == "debug") debug = (llToLower(cfg_val) == "true");
    else if(debug) llOwnerSay("Unknown config: " + cfg_key);
}

