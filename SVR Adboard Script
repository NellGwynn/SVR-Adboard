// ==================================================
// FUNCTION: PROCESS RENTAL TIME CHECK
// =================================================
ProcTimeChkRent()
{
    if(debug) llOwnerSay("Checking time");
    
    integer elapsed_time = llGetUnixTime() - g_begin_time;
    integer remaining_time = g_activ_time - elapsed_time;
    
    if(remaining_time <= 0)
    {
        RentTimeEnd();
        return;
    }
    
    string time_string = fmtRemainTime(remaining_time);
    if(debug) llOwnerSay("Remaining: " + time_string);
    
    integer days = llFloor(remaining_time / 86400);
    integer hours = llFloor((remaining_time % 86400) / 3600);
    integer minutes = llFloor((remaining_time % 3600) / 60);
    
    if (days <= g_notify_days)
    {
        if (days == g_notify_days)
            WarnExpire(remaining_time);
        else if (days == 1 && hours == 0)
            WarnExpire(remaining_time);
        else if (days == 0)
        {
            if (hours == 12 || hours == 1 || (hours == 0 && minutes == 30))
                WarnExpire(remaining_time);
        }
    }
}

